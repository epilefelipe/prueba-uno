        <!-- 6. Backend -> Acquirer -->
        <mxCell id="m6" value="6. Authorization Request&#xa;{ amount: 75.50, currency: 'USD',&#xa;  cardToken: 'tok_test_123' }" style="html=1;verticalAlign=bottom;endArrow=block;entryX=0;entryY=0;strokeColor=#9A3412;strokeWidth=1.5;fontColor=#9A3412;fontSize=9;labelBackgroundColor=#F8FAFC;" edge="1" parent="s1" target="act-acquirer-1">
