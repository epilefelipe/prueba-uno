        <!-- 4. Backend -> Audit -->
        <mxCell id="m4" value="4. logEvent(&#xa;  'AUTHORIZATION_STARTED'&#xa;)" style="html=1;verticalAlign=bottom;endArrow=block;entryX=0;entryY=0;strokeColor=#5B21B6;strokeWidth=1.5;fontColor=#5B21B6;fontSize=9;labelBackgroundColor=#F8FAFC;" edge="1" parent="s1" target="act-audit-1">
